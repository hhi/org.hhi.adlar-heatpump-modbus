{
  "id": "set_setpoint_for_mode",
  "title": {
    "en": "Set setpoint temperature (by mode)",
    "nl": "Setpoint temperatuur instellen (per modus)",
    "de": "Sollwert-Temperatur einstellen (nach Modus)",
    "fr": "Régler la température de consigne (par mode)"
  },
  "titleFormatted": {
    "en": "Set setpoint to [[temperature]] for [[target]] [[decimal_handling]]",
    "nl": "Setpoint instellen op [[temperature]] voor [[target]] [[decimal_handling]]",
    "de": "Sollwert einstellen auf [[temperature]] für [[target]] [[decimal_handling]]",
    "fr": "Régler la consigne sur [[temperature]] pour [[target]] [[decimal_handling]]"
  },
  "hint": {
    "en": "Set the setpoint temperature, routed to heating, cooling, or floor heating. Auto follows the heat pump's current mode.",
    "nl": "Stel de setpoint temperatuur in, gericht op verwarmen, koelen of vloerverwarming. Auto volgt de huidige modus van de warmtepomp.",
    "de": "Sollwert-Temperatur einstellen, geleitet an Heizen, Kühlen oder Fußbodenheizung. Auto folgt dem aktuellen Modus der Wärmepumpe.",
    "fr": "Régler la température de consigne, dirigée vers chauffage, refroidissement ou plancher chauffant. Auto suit le mode actuel de la pompe à chaleur."
  },
  "highlight": true,
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=intelligent-heatpump-modbus"
    },
    {
      "type": "range",
      "name": "temperature",
      "title": {
        "en": " Temperature (°C)",
        "nl": " Temperatuur (°C)",
        "de": " Temperatur (°C)",
        "fr": " Température (°C)"
      },
      "min": 7,
      "max": 60,
      "step": 1,
      "units": "°C",
      "placeholder": {
        "en": "Target temperature in °C",
        "nl": "Doel temperatuur in °C",
        "de": "Zieltemperatur in °C",
        "fr": "Température cible en °C"
      }
    },
    {
      "type": "dropdown",
      "name": "target",
      "title": {
        "en": "Apply to",
        "nl": "Toepassen op",
        "de": "Anwenden auf",
        "fr": "Appliquer à"
      },
      "values": [
        {
          "id": "auto",
          "label": {
            "en": "Auto (follow current mode)",
            "nl": "Auto (volg huidige modus)",
            "de": "Auto (aktuellem Modus folgen)",
            "fr": "Auto (suivre le mode actuel)"
          }
        },
        {
          "id": "heating",
          "label": {
            "en": "Heating",
            "nl": "Verwarmen",
            "de": "Heizen",
            "fr": "Chauffage"
          }
        },
        {
          "id": "cooling",
          "label": {
            "en": "Cooling",
            "nl": "Koelen",
            "de": "Kühlen",
            "fr": "Refroidissement"
          }
        },
        {
          "id": "floor",
          "label": {
            "en": "Floor heating",
            "nl": "Vloerverwarming",
            "de": "Fußbodenheizung",
            "fr": "Plancher chauffant"
          }
        }
      ],
      "value": "auto"
    },
    {
      "type": "dropdown",
      "name": "decimal_handling",
      "title": {
        "en": "If decimal value",
        "nl": "Bij decimale waarde",
        "de": "Bei Dezimalwert",
        "fr": "Si valeur décimale"
      },
      "values": [
        {
          "id": "round",
          "label": {
            "en": "Auto-round (recommended)",
            "nl": "Automatisch afronden (aanbevolen)",
            "de": "Automatisch runden (empfohlen)",
            "fr": "Arrondir automatiquement (recommandé)"
          }
        },
        {
          "id": "error",
          "label": {
            "en": "Show error",
            "nl": "Foutmelding tonen",
            "de": "Fehler anzeigen",
            "fr": "Afficher erreur"
          }
        }
      ],
      "value": "round"
    }
  ]
}
