      {
        "id": "flow_efficiency_alerts",
        "type": "dropdown",
        "label": {
          "en": "Efficiency alerts",
          "nl": "Efficiëntiemeldingen"
        },
        "value": "auto",
        "values": [
          { "id": "disabled", "label": { "en": "Disabled", "nl": "Uitgeschakeld" } },
          { "id": "auto", "label": { "en": "Auto", "nl": "Automatisch" } },
          { "id": "enabled", "label": { "en": "Enabled", "nl": "Ingeschakeld" } }
        ]
      },
      {
        "id": "flow_state_alerts",
        "type": "dropdown",
        "label": {
          "en": "State change alerts",
