  {
    "id": "cop_efficiency",
    "type": "group",
    "label": {
      "en": "COP & Efficiency",
      "nl": "COP & Efficiëntie"
    },
    "children": [
      {
        "id": "cop_calculation_enabled",
        "type": "checkbox",
        "label": {
          "en": "Enable COP calculation",
          "nl": "COP-berekening inschakelen"
        },
        "value": true
      },
      {
        "id": "cop_outlier_detection_enabled",
        "type": "checkbox",
        "label": {
          "en": "Enable outlier detection",
          "nl": "Detectie van uitschieters inschakelen"
        },
        "value": true,
        "hint": {
          "en": "Filters unrealistic COP values from calculations.",
          "nl": "Filtert onrealistische COP-waarden uit berekeningen."
        }
      },
      {
        "id": "cop_min_threshold",
        "type": "number",
        "label": {
          "en": "Minimum COP threshold",
          "nl": "Minimum COP-drempelwaarde"
        },
        "value": 1.0,
        "attr": {
          "min": 0.5,
          "max": 2.0,
          "step": 0.1
        }
      },
      {
        "id": "cop_max_threshold",
        "type": "number",
        "label": {
          "en": "Maximum COP threshold",
          "nl": "Maximum COP-drempelwaarde"
        },
        "value": 7.0,
        "attr": {
          "min": 4.0,
          "max": 9.0,
          "step": 0.1
        }
      }
    ]
  },
  {
    "id": "features",
    "type": "group",
    "label": {
      "en": "Features",
      "nl": "Functies"
    },
    "children": [
      {
        "id": "enable_power_measurements",
        "type": "checkbox",
        "label": {
          "en": "Enable power measurements",
          "nl": "Vermogensmetingen inschakelen"
        },
        "value": true,
        "hint": {
          "en": "Enables tracking of power consumption for COP and energy calculations.",
          "nl": "Schakelt bijhouden van stroomverbruik in voor COP- en energieberekeningen."
        }
      },
      {
        "id": "enable_intelligent_energy_tracking",
        "type": "checkbox",
        "label": {
          "en": "Enable intelligent energy tracking",
          "nl": "Intelligente energiebewaking inschakelen"
        },
        "value": true,
        "hint": {
          "en": "Tracks daily and cumulative energy consumption and cost.",
          "nl": "Bijhouden van dagelijks en cumulatief energieverbruik en kosten."
        }
      }
    ]
  },
  {
