  {
    "id": "adaptive_control",
    "type": "group",
    "label": {
      "en": "Adaptive Control",
      "nl": "Adaptieve Regeling"
    },
    "children": [
      {
        "id": "adaptive_control_enabled",
        "type": "checkbox",
        "label": {
          "en": "Enable adaptive control",
          "nl": "Adaptieve regeling inschakelen"
        },
        "value": false,
        "hint": {
          "en": "Automatically adjusts heating setpoint based on indoor temperature feedback.",
          "nl": "Past het verwarmingsinstelpunt automatisch aan op basis van binnentemperatuur."
        }
      },
      {
        "id": "adaptive_pi_kp",
        "type": "number",
        "label": {
          "en": "PI proportional gain (Kp)",
          "nl": "PI proportionele versterking (Kp)"
        },
        "value": 0.8,
        "attr": { "min": 0.1, "max": 5.0, "step": 0.1 }
      },
      {
        "id": "adaptive_pi_ki",
        "type": "number",
        "label": {
          "en": "PI integral gain (Ki)",
          "nl": "PI integrerende versterking (Ki)"
        },
        "value": 0.05,
        "attr": { "min": 0.001, "max": 1.0, "step": 0.001 }
      },
      {
        "id": "adaptive_pi_deadband",
        "type": "number",
        "label": {
          "en": "PI deadband (°C)",
          "nl": "PI dode zone (°C)"
        },
        "value": 0.3,
        "attr": { "min": 0.1, "max": 2.0, "step": 0.1 }
      },
      {
        "id": "adaptive_min_setpoint",
        "type": "number",
        "label": {
          "en": "Minimum setpoint (°C)",
          "nl": "Minimaal instelpunt (°C)"
        },
        "value": 25,
        "attr": { "min": 20, "max": 45, "step": 1 }
      },
      {
        "id": "adaptive_cooldown_offset",
        "type": "number",
        "label": {
          "en": "Cooldown offset (°C)",
          "nl": "Afkoelcompensatie (°C)"
        },
        "value": 3.0,
        "attr": { "min": 0.5, "max": 10.0, "step": 0.5 }
      },
      {
        "id": "adaptive_cooldown_hysteresis",
        "type": "number",
        "label": {
          "en": "Cooldown hysteresis (°C)",
          "nl": "Afkoelhysterese (°C)"
        },
        "value": 1.5,
        "attr": { "min": 0.5, "max": 5.0, "step": 0.5 }
      },
      {
        "id": "adaptive_cooldown_strength",
        "type": "number",
        "label": {
          "en": "Cooldown strength (0–1)",
          "nl": "Afkoelsterkte (0–1)"
        },
        "value": 0.7,
        "attr": { "min": 0.1, "max": 1.0, "step": 0.1 }
      }
    ]
  },
  {
    "id": "building_model",
    "type": "group",
    "label": {
      "en": "Building Model",
      "nl": "Gebouwmodel"
    },
    "children": [
      {
        "id": "building_model_enabled",
        "type": "checkbox",
        "label": {
          "en": "Enable building model learning",
          "nl": "Gebouwmodel leren inschakelen"
        },
        "value": false,
        "hint": {
          "en": "Learns thermal parameters (C, UA, τ) from operational data.",
          "nl": "Leert thermische parameters (C, UA, τ) van operationele data."
        }
      },
      {
        "id": "building_model_forgetting_factor",
        "type": "number",
        "label": {
          "en": "Forgetting factor (λ)",
          "nl": "Vergeetfactor (λ)"
        },
        "value": 0.99,
        "hint": {
          "en": "Lower values adapt faster to changes but forget history more quickly.",
          "nl": "Lagere waarden passen zich sneller aan maar vergeten geschiedenis sneller."
        },
        "attr": { "min": 0.90, "max": 0.999, "step": 0.001 }
      },
      {
        "id": "building_profile",
        "type": "dropdown",
        "label": {
          "en": "Building profile",
          "nl": "Gebouwprofiel"
        },
        "value": "average",
        "hint": {
          "en": "Initial thermal profile used until model has learned enough data.",
          "nl": "Initieel thermisch profiel totdat het model voldoende data heeft geleerd."
        },
        "values": [
          { "id": "light", "label": { "en": "Light (fast response)", "nl": "Licht (snelle respons)" } },
          { "id": "average", "label": { "en": "Average (default)", "nl": "Gemiddeld (standaard)" } },
          { "id": "heavy", "label": { "en": "Heavy (slow response)", "nl": "Zwaar (trage respons)" } },
          { "id": "passive", "label": { "en": "Passive house (very slow)", "nl": "Passief huis (zeer traag)" } }
        ]
      },
      {
        "id": "reset_building_model",
        "type": "checkbox",
        "label": {
          "en": "Reset building model (clears learned data)",
          "nl": "Gebouwmodel resetten (wist geleerde data)"
        },
        "value": false,
        "hint": {
          "en": "Enabling this and saving will reset all learned thermal parameters.",
          "nl": "Dit inschakelen en opslaan reset alle geleerde thermische parameters."
        }
      },
      {
        "id": "enable_dynamic_pint",
        "type": "checkbox",
        "label": {
          "en": "Enable dynamic internal heat gain",
          "nl": "Dynamische interne warmtewinst inschakelen"
        },
        "value": true,
        "hint": {
          "en": "Allows model to learn internal heat gain (P_int) from occupancy patterns.",
          "nl": "Staat model toe interne warmtewinst (P_int) te leren van bezettingspatronen."
        }
      }
    ]
  },
  {
    "id": "building_insights",
    "type": "group",
    "label": {
      "en": "Building Insights",
      "nl": "Gebouwinzichten"
    },
    "children": [
      {
        "id": "building_insights_enabled",
        "type": "checkbox",
        "label": {
          "en": "Enable building insights",
          "nl": "Gebouwinzichten inschakelen"
