        "value": 10,
        "attr": {
          "min": 5,
          "max": 60
        }
      },
      {
        "id": "poll_medium_s",
        "type": "number",
        "label": {
          "en": "Medium poll interval (seconds)",
          "nl": "Medium poll-interval (seconden)"
        },
        "value": 30,
        "attr": {
          "min": 15,
          "max": 300
